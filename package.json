{
    "name": "key-vault",
    "version": "3.2.0",
    "description": "A Google Apps Script web app for managing event stream keys with role-based access.",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node build-tools/dev.mjs",
        "css": "tailwindcss -i ./frontend/input.css -o ./frontend/output.css",
        "apps-script:build": "node build-tools/build-apps-script.mjs",
        "version:check": "node build-tools/check-version.mjs",
        "test": "node test/run-tests.mjs",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@google/clasp": "^3.3.0",
        "@tailwindcss/cli": "^4.2.1",
        "@tailwindcss/typography": "^0.5.19",
        "browser-sync": "^3.0.4",
        "concurrently": "^9.2.1",
        "daisyui": "^5.5.19",
        "execa": "^9.6.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.2.1"
    }
}
